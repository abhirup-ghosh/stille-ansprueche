{
  "id": null,
  "uid": "stille-ansprueche-monitoring",
  "title": "Stille Anspr\u00fcche \u2014 Monitoring",
  "tags": [
    "stille-ansprueche"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Total conversations",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 6
      },
      "datasource": {
        "type": "postgres",
        "uid": "stille_postgres"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "stille_postgres"
          },
          "format": "table",
          "rawSql": "SELECT count(*) AS total_conversations FROM conversations",
          "refId": "A",
          "rawQuery": true,
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 2,
      "title": "Conversations per hour",
      "type": "timeseries",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 18,
        "h": 6
      },
      "datasource": {
        "type": "postgres",
        "uid": "stille_postgres"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "stille_postgres"
          },
          "format": "time_series",
          "rawSql": "SELECT date_trunc('hour', ts) AS \"time\", count(*) AS \"conversations\" FROM conversations WHERE $__timeFilter(ts) GROUP BY 1 ORDER BY 1",
          "refId": "A",
          "rawQuery": true,
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 3,
      "title": "Feedback: \ud83d\udc4d vs \ud83d\udc4e",
      "type": "piechart",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "stille_postgres"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "stille_postgres"
          },
          "format": "table",
          "rawSql": "SELECT case value when 1 then 'up' else 'down' end AS metric, count(*) AS value FROM feedback GROUP BY 1",
          "refId": "A",
          "rawQuery": true,
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 4,
      "title": "Relevance label distribution",
      "type": "piechart",
      "gridPos": {
        "x": 8,
        "y": 6,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "stille_postgres"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "stille_postgres"
          },
          "format": "table",
          "rawSql": "SELECT coalesce(relevance, '(pending)') AS metric, count(*) AS value FROM conversations GROUP BY 1",
          "refId": "A",
          "rawQuery": true,
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 5,
      "title": "Question language distribution",
      "type": "barchart",
      "gridPos": {
        "x": 16,
        "y": 6,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "stille_postgres"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "stille_postgres"
          },
          "format": "table",
          "rawSql": "SELECT coalesce(lang, 'unknown') AS lang, count(*) AS count FROM conversations GROUP BY 1 ORDER BY 1",
          "refId": "A",
          "rawQuery": true,
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 6,
      "title": "Avg response time (s)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "stille_postgres"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "stille_postgres"
          },
          "format": "time_series",
          "rawSql": "SELECT date_trunc('hour', ts) AS \"time\", avg(response_time_s) AS \"avg_response_time_s\" FROM conversations WHERE $__timeFilter(ts) GROUP BY 1 ORDER BY 1",
          "refId": "A",
          "rawQuery": true,
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 7,
      "title": "Cumulative cost (USD)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "stille_postgres"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "stille_postgres"
          },
          "format": "time_series",
          "rawSql": "SELECT time, sum(cost_usd) OVER (ORDER BY time) AS \"cumulative_cost_usd\" FROM (SELECT date_trunc('hour', ts) AS \"time\", sum(cost_usd) AS cost_usd FROM conversations WHERE $__timeFilter(ts) GROUP BY 1) t ORDER BY time",
          "refId": "A",
          "rawQuery": true,
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 8,
      "title": "Top 10 retrieved benefits",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "stille_postgres"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "stille_postgres"
          },
          "format": "table",
          "rawSql": "SELECT unnest(retrieved_ids) AS benefit_id, count(*) AS times_retrieved FROM conversations GROUP BY 1 ORDER BY 2 DESC LIMIT 10",
          "refId": "A",
          "rawQuery": true,
          "editorMode": "code"
        }
      ]
    }
  ]
}
